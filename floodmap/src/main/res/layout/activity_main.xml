<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#1a1a2e">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/nav_bar" />

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:layout_above="@id/nav_bar"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flood Watch"
            android:textSize="36sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ladywood Flood Map"
            android:textSize="16sp"
            android:textColor="#aaaaaa"
            android:layout_marginBottom="48dp"/>

        <Button
            android:id="@+id/btnLiveData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Live Flood Data"
            android:backgroundTint="#0077b6"
            android:textColor="#ffffff"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:radius="1dp" />


        <Button
            android:id="@+id/btnTestData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Data (Demo Mode)"
            android:backgroundTint="#2d6a4f"
            android:textColor="#ffffff"
            android:padding="16dp"
            android:radius="1dp" />

        <Button
            android:id="@+id/btnControllerData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text= "Accesibility mode"
            android:backgroundTint="#E84415"
            android:textColor="#ffffff"
            android:layout_margin="30dp"
            android:padding="16dp"
            android:radius="30dp" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/nav_bar" />

</RelativeLayout>